---
import Layout from '../../layouts/Layout.astro';
import ClausulaCard from '../../components/ClausulaCard.astro';
import { getCollection } from 'astro:content';

const kbEntries = await getCollection('knowledgeBase');
const reunioes  = await getCollection('reunioes');

const clausulasInfo = [
  { num: 4,  title: 'Contexto Organizacional',  slug: 'clausula_4_contexto_organizacional'  },
  { num: 5,  title: 'Liderança',                 slug: 'clausula_5_lideranca'                },
  { num: 6,  title: 'Planejamento',              slug: 'clausula_6_planejamento'             },
  { num: 7,  title: 'Apoio',                     slug: 'clausula_7_suporte'                  },
  { num: 8,  title: 'Operação',                  slug: 'clausula_8_operacao'                 },
  { num: 9,  title: 'Avaliação de Desempenho',   slug: 'clausula_9_avaliacao_desempenho'     },
  { num: 10, title: 'Melhoria',                  slug: 'clausula_10_melhoria'                },
];

const clausulasStats = clausulasInfo.map(c => {
  const entries = kbEntries.filter(e =>
    e.id.startsWith(c.slug + '/') && !e.id.endsWith('_overview')
  );
  const hasOverview = kbEntries.some(e => e.id === c.slug + '/_overview');
  return { ...c, aprendizados: entries.length, hasOverview };
});
---

<Layout title="Central de Conhecimento" section="base">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6">
    <a href="/" class="hover:text-slate-600">Início</a>
    <span>/</span>
    <span class="text-slate-700 font-medium">Central de Conhecimento</span>
  </nav>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-1">Central de Conhecimento</h1>
    <p class="text-slate-500">Metodologia ISO 9001:2015 — organizada por cláusula normativa.</p>
  </div>

  <!-- Cláusulas -->
  <section class="mb-10">
    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-4">Cláusulas ISO 9001:2015</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {clausulasStats.map(c => (
        <ClausulaCard
          num={c.num}
          title={c.title}
          slug={c.slug}
          aprendizados={c.aprendizados}
          hasOverview={c.hasOverview}
        />
      ))}
    </div>
  </section>

  <!-- Atalhos -->
  <section>
    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-4">Recursos transversais</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <a
        href="/base/reunioes"
        class="flex items-center gap-4 bg-white rounded-xl border border-slate-200 hover:border-indigo-300 p-5 transition-all group hover:shadow-sm"
      >
        <span class="text-2xl">🎙️</span>
        <div>
          <div class="font-semibold text-slate-800 group-hover:text-indigo-700">Reuniões</div>
          <div class="text-xs text-slate-500 mt-0.5">{reunioes.length} reunião{reunioes.length !== 1 ? 'ões' : ''} registrada{reunioes.length !== 1 ? 's' : ''}</div>
        </div>
        <span class="ml-auto text-slate-300 group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all">→</span>
      </a>

      <a
        href="/base/glossario"
        class="flex items-center gap-4 bg-white rounded-xl border border-slate-200 hover:border-indigo-300 p-5 transition-all group hover:shadow-sm"
      >
        <span class="text-2xl">📖</span>
        <div>
          <div class="font-semibold text-slate-800 group-hover:text-indigo-700">Glossário</div>
          <div class="text-xs text-slate-500 mt-0.5">Terminologia ISO ↔ Judiciário</div>
        </div>
        <span class="ml-auto text-slate-300 group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all">→</span>
      </a>

    </div>
  </section>

</Layout>
