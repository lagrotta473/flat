---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const reunioes = await getCollection('reunioes');

const reunioesFormatadas = reunioes.map(r => {
  const dateMatch = r.id.match(/^(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : '';
  const label = r.id
    .replace(/^\d{4}-\d{2}-\d{2}_/, '')
    .replace(/^reuniao_/, '')
    .replace(/-/g, ' ');
  return { entry: r, date, label };
}).sort((a, b) => b.date.localeCompare(a.date));
---

<Layout title="Reuniões" section="base">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6">
    <a href="/" class="hover:text-slate-600">Início</a>
    <span>/</span>
    <a href="/base" class="hover:text-slate-600">Central de Conhecimento</a>
    <span>/</span>
    <span class="text-slate-700 font-medium">Reuniões</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-1">Reuniões</h1>
    <p class="text-slate-500 text-sm">Transcrições e relatos das reuniões com o professor e as organizações.</p>
  </div>

  {reunioesFormatadas.length > 0 ? (
    <div class="space-y-3">
      {reunioesFormatadas.map(({ entry, date, label }) => (
        <a
          href={`/base/reunioes/${entry.id}`}
          class="flex items-center gap-4 bg-white rounded-xl border border-slate-200 hover:border-indigo-300 p-5 transition-all group hover:shadow-sm"
        >
          <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center text-xl">🎙️</span>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-slate-800 group-hover:text-indigo-700 capitalize">{label}</div>
            <div class="text-xs text-slate-400 mt-0.5 font-mono">{date}</div>
          </div>
          <span class="text-slate-300 group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all flex-shrink-0">→</span>
        </a>
      ))}
    </div>
  ) : (
    <div class="bg-slate-50 border border-dashed border-slate-200 rounded-xl p-10 text-center text-slate-400">
      <div class="text-3xl mb-3">🎙️</div>
      <div class="font-medium">Nenhuma reunião registrada ainda.</div>
      <div class="text-sm mt-1">Adicione arquivos em <code class="bg-slate-200 px-1 rounded">/references/reunioes/</code></div>
    </div>
  )}

</Layout>
